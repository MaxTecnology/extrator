APP_PORT=8001
APP_NAME=carimbo-service
VERSION=1.0.0

DPI_RENDER=300
MIN_CONTOUR_AREA=4000
PADDING_PX=20
FALLBACK_ROI_Y_START=0.55
FALLBACK_ROI_X_END=0.55
MAX_FILE_SIZE_MB=20

GEMINI_API_KEY=
GEMINI_DETECTION_ENABLED=true
GEMINI_DETECTION_MODEL=gemini-2.5-flash
GEMINI_EXTRACTION_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=30
GEMINI_MAX_CANDIDATES=3
GEMINI_MAX_EVALUATIONS=6
GEMINI_DETECTION_RETRY_ATTEMPTS_CAP=2
GEMINI_EXTRACTION_RETRY_ATTEMPTS_CAP=1
GEMINI_RETRY_ATTEMPTS=3
GEMINI_RETRY_BACKOFF_SECONDS=1.2
GEMINI_RETRY_JITTER_SECONDS=0.35

STAMP_BOTTOM_PRIORITY_Y_START=0.60
STAMP_BOTTOM_PRIORITY_X_END=0.80

IMAGE_ARTIFACTS_DIR=/tmp/carimbo-artifacts
IMAGE_ARTIFACTS_URL_PREFIX=/artifacts

SOC_ENABLED=true
SOC_BASE_URL=https://ws1.soc.com.br/WebSoc/exportadados
SOC_EMPRESA=
SOC_CODIGO=
SOC_CHAVE=
SOC_TIPO_SAIDA=json
SOC_TIMEOUT_SECONDS=15
SOC_NAME_SIMILARITY_THRESHOLD=0.78
